# SparkReel — environment configuration template.
# Copy to .env and fill in.  Load it before running, e.g.:
#     set -a && . ./.env && set +a
# NEVER commit your real .env — it is gitignored.

# ── Team console ─────────────────────────────────────────────────────────────
# The console can drive a shell (the optional SparkAgent, below). ALWAYS set a
# strong password for any shared or internet-reachable deployment. If left unset,
# a random one-time password is generated at startup and printed to the terminal.
SPARKREEL_CONSOLE_PASSWORD=

# Enable the in-console AI dev-agent (OFF by default). When on, anyone who has the
# console password can read/write files and run commands on the host. Keep the
# console on a trusted network and use a strong password.
SPARKREEL_AGENT_ENABLED=0
# Agent backend: auto | cli (local logged-in claude/codex) | api (keys below) | bedrock (AWS IAM role)
SPARKREEL_AGENT_BACKEND=auto

# ── AI providers (only needed for the "api" agent backend) ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── AWS / Bedrock (for the aws capability backends & the bedrock agent) ───────
# On EC2, prefer an instance IAM role — no keys needed. Otherwise use ~/.aws or
# the standard AWS_* vars below. Grant least privilege (e.g. bedrock:InvokeModel).
SPARKREEL_CLOUD=0                 # 1 = route every capability to AWS
AWS_REGION=us-east-1
SPARKREEL_BEDROCK_MODEL=          # e.g. us.anthropic.claude-... (cross-region inference profile id)
# AWS_ACCESS_KEY_ID=             # only if NOT using an instance role / ~/.aws profile
# AWS_SECRET_ACCESS_KEY=
